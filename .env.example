# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Lead Proxy Configuration
# LEAD_PROXY_URL is a SERVER-SIDE-ONLY env var (no NEXT_PUBLIC_ prefix)
# It holds the Railway backend proxy URL and must NEVER be exposed to the client bundle.
LEAD_PROXY_URL="https://newera-lead-proxy.up.railway.app/api/lead-submit"

# NEXT_PUBLIC_LEAD_PROXY_URL is used only if you want to bypass the local API route
# (optional — omit this to always use the secure /api/lead-submit local route)
# NEXT_PUBLIC_LEAD_PROXY_URL=
