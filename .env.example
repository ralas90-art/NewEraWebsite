# ==========================================
# Server-Side Only Variables (DO NOT expose in client bundle!)
# ==========================================
# LEAD_PROXY_URL: The URL of the backend lead proxy on Railway.
# Used by the local /api/lead-submit route to securely forward lead payloads.
LEAD_PROXY_URL="https://newera-lead-proxy.up.railway.app/api/lead-submit"

# GEMINI_API_KEY: Required for Gemini AI API calls on the server.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The base URL of the application.
APP_URL="MY_APP_URL"

# ==========================================
# Client-Side Tracking Variables (Safe for client bundle)
# ==========================================
# These will be loaded dynamically. If missing, tracking scripts fail silently.
# Do not hardcode these values in the codebase.
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_GTM_ID=""
NEXT_PUBLIC_GA4_ID=""
NEXT_PUBLIC_CLARITY_ID=""
